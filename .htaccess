<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /vida_estudiantil_Hitha/

# ==============================
# ARCHIVOS Y DIRECTORIOS REALES
# ==============================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ==============================
# COMPAT: assets/* → cpanel/assets/*
# Permite que URLs antiguas de imágenes sigan funcionando
# ==============================
RewriteRule ^assets/(.*)$ cpanel/assets/$1 [L]

# ==============================
# RAÍZ → redirigir al cpanel
# ==============================
RewriteRule ^/?$ cpanel/ [R=302,L]

</IfModule>
