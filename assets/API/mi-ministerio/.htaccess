RewriteEngine On

# Permitir acceso directo a archivos
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Permitir directorios
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Remover .php de las URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)$ $1.php [NC,L]
