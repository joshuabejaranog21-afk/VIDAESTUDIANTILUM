<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /Vida%20Estudiantil/cpanel/

# ==============================
# ARCHIVOS Y DIRECTORIOS REALES
# ==============================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ==============================
# EXCLUIR CARPETAS ESPECIALES
# ==============================
RewriteRule ^(assets|uploads|configuracion)/ - [L]

# ==============================
# ELIMINAR EXTENSIÓN .PHP
# ==============================
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# ==============================
# PULSO - MANEJO ESPECIAL
# ==============================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/Vida%20Estudiantil/cpanel/pulso/$1.php -f
RewriteRule ^pulso/(.+)$ pulso/$1.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/Vida%20Estudiantil/cpanel/pages/pulso/$1.php -f
RewriteRule ^pulso/(.+)$ pages/pulso/$1.php [L]

# ==============================
# ARCHIVOS RAÍZ DEL CPANEL
# ==============================
RewriteRule ^/?$ index.php [L]
RewriteRule ^login/?$ login.php [L]
RewriteRule ^home/?$ home.php [L]
RewriteRule ^mi-foto/?$ mi-foto.php [L]
RewriteRule ^federacion/?$ federacion.php [L]

# ==============================
# ANUARIOS
# ==============================
RewriteRule ^anuarios/?$ pages/anuarios/index.php [L]
RewriteRule ^anuarios/admin/?$ pages/anuarios/admin/index.php [L]
RewriteRule ^anuarios/admin/fotos-estudiantes/?$ pages/anuarios/admin/fotos-estudiantes.php [L]
RewriteRule ^anuarios/admin/extraer-flickr/?$ pages/anuarios/admin/extraer-flickr.php [L]
RewriteRule ^anuarios/mis-fotos/?$ pages/anuarios/mis-fotos.php [L]
RewriteRule ^anuarios/ver/?$ pages/anuarios/ver.php [L]
RewriteRule ^anuarios/visor-pdf/?$ pages/anuarios/visor-pdf.php [L]

# ==============================
# REDIRECCIÓN GENERAL A /pages/
# ==============================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/Vida%20Estudiantil/cpanel/pages/$1.php -f
RewriteRule ^(.+)$ pages/$1.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ pages/$1 [L]

</IfModule>
