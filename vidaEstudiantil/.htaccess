<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /vida_estudiantil_Hitha/vidaEstudiantil/

# Archivos y directorios reales - no reescribir
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# No tocar assets
RewriteRule ^assets/ - [L]

# Rutas amigables
RewriteRule ^clubes/?$                    clubes.php [L]
RewriteRule ^ministerios/?$              ministerios.php [L]
RewriteRule ^eventos/?$                   eventos.php [L]
RewriteRule ^instalaciones/?$            instalaciones.php [L]
RewriteRule ^deportes/?$                  deportes.php [L]
RewriteRule ^anuarios/?$                  anuarios.php [L]
RewriteRule ^club/([0-9]+)/?$            club.php?id=$1 [L,QSA]
RewriteRule ^ministerio/([0-9]+)/?$      ministerio.php?id=$1 [L,QSA]
RewriteRule ^instalacion/([0-9]+)/?$     instalacion.php?id=$1 [L,QSA]
RewriteRule ^deporte/([0-9]+)/?$         deporte.php?id=$1 [L,QSA]

# Raíz
RewriteRule ^$                            index.php [L]
</IfModule>
